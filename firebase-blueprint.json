{
  "entities": {
    "Sale": {
      "title": "Sale",
      "description": "A service sale record",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "serviceName": { "type": "string" },
        "professionalName": { "type": "string" },
        "clientName": { "type": "string" },
        "totalAmount": { "type": "number" },
        "costAmount": { "type": "number" },
        "quantity": { "type": "number" },
        "commissionType": { "type": "string", "enum": ["percentage", "fixed"] },
        "commissionPercentage": { "type": "number" },
        "commissionAmount": { "type": "number" },
        "netAmount": { "type": "number" },
        "ivaAmount": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["date", "totalAmount", "userId"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A business expense",
      "type": "object",
      "properties": {
        "category": { "type": "string", "enum": ["arriendo", "servicios básicos", "marketing", "software", "insumos", "operación"] },
        "type": { "type": "string", "enum": ["fijo", "variable"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["category", "type", "amount", "date", "userId"]
    },
    "AIAnalysis": {
      "title": "AIAnalysis",
      "description": "Daily financial analysis generated by AI",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "positives": { "type": "array", "items": { "type": "string" } },
        "improvements": { "type": "array", "items": { "type": "string" } },
        "alerts": { "type": "array", "items": { "type": "string" } },
        "tips": { "type": "array", "items": { "type": "string" } },
        "summary": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["date", "userId"]
    },
    "Settings": {
      "title": "Settings",
      "description": "User specific settings like commission rules and service prices",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "commissionRules": { "type": "object" },
        "servicePrices": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "commissionRules"]
    }
  },
  "firestore": {
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Collection of sales"
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Collection of expenses"
    },
    "/analyses/{analysisId}": {
      "schema": "AIAnalysis",
      "description": "Collection of daily AI analyses"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "User settings"
    }
  }
}
